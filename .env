# =========================
# APP CONFIG
# =========================
APP_NAME=entropia-windows
ENV=development
API_VERSION=3.2.0
API_V1_PREFIX=/api
PORT=8000

# =========================
# BACKEND / FRONTEND
# =========================
API_URL=http://entropia-api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# =========================
# DATABASE
# =========================
DATABASE_URL=sqlite:///./data/windows.db
REDIS_URL=redis://redis:6379/0

# =========================
# OLLAMA (CRÍTICO)
# =========================
OLLAMA_BASE_URL=http://entropia-ollama:11434
OLLAMA_MODEL=llava:7b
OLLAMA_TIMEOUT=300

# =========================
# STORAGE
# =========================
UPLOAD_DIR=uploads/windows
MAX_FILE_SIZE=5242880

# =========================
# LOGIC
# =========================
HAMMING_THRESHOLD=10