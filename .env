# =========================
# APP CONFIG
# =========================
APP_NAME=entropia-windows
ENV=development
API_VERSION=3.2.0
API_V1_PREFIX=/api
PORT=3000

# =========================
# BACKEND (Comunicación interna Docker)
# =========================
# Esta es la URL que el Frontend usará si hace Server Side Rendering (SSR)
API_URL=http://entropia-api:8000

# =========================
# FRONTEND (Desde el navegador del usuario)
# =========================
# IMPORTANTE: localhost funciona solo si accedes desde la misma PC
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# =========================
# DATABASE / PERSISTENCE
# =========================
# Asegúrate de que el volumen esté montado en /app/data en el compose
DATABASE_URL=sqlite:///./data/windows.db
REDIS_URL=redis://redis:6379/0

# =========================
# OLLAMA CONFIG
# =========================
# Usamos el nombre del servicio definido en docker-compose
OLLAMA_BASE_URL=http://entropia-ollama:11434

# IMPORTANTE: Debe ser exactamente igual al que pongas en 'ollama pull' en start.sh
OLLAMA_MODEL=llava:7b

# Tiempo de espera en segundos para que el modelo responda (7B requiere tiempo)
OLLAMA_TIMEOUT=300

# =========================
# STORAGE
# =========================
# Rutas relativas dentro del contenedor del backend
UPLOAD_DIR=uploads/windows
MAX_FILE_SIZE=5242880

# =========================
# LOGIC PARAMETERS
# =========================
HAMMING_THRESHOLD=10