# =========================
# PORTS
# =========================
PORT=3000

# =========================
# BACKEND (Docker internal)
# =========================
API_URL=http://entropia-api:8000

# =========================
# FRONTEND (browser)
# =========================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =========================
# APP
# =========================
APP_NAME=entropia-windows
ENV=development
API_VERSION=3.2.0
API_V1_PREFIX=/api

# =========================
# DATABASE
# =========================
DATABASE_URL=sqlite:///./data/windows.db

# =========================
# REDIS
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# OLLAMA
# =========================
OLLAMA_BASE_URL=http://entropia-ollama:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT=30

# =========================
# FILES
# =========================
UPLOAD_DIR=uploads/windows
MAX_FILE_SIZE=5242880

# =========================
# HASH
# =========================
HAMMING_THRESHOLD=10

# =========================
# FRONTEND URL
# =========================
FRONTEND_URL=http://localhost:3000
